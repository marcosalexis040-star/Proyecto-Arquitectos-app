# Copia este archivo a .env y ajusta los valores. NUNCA commitees el .env real.

# Puerto del servidor HTTP
PORT=3000

# Modo simulado: "true" devuelve una especificación de ejemplo sin llamar a
# ningún proveedor de IA (útil para desarrollar y probar la lógica del
# endpoint sin gastar crédito). Cambia a "false" y configura UNA de las dos
# keys de abajo cuando quieras especificaciones reales.
MOCK_CLAUDE=true

# --- Opción A: API directa de Anthropic (https://platform.claude.com) ---
ANTHROPIC_API_KEY=

# --- Opción B: OpenRouter (https://openrouter.ai) ---
# Alternativa si ya tienes crédito en OpenRouter. Si defines
# OPENROUTER_API_KEY, tiene prioridad sobre ANTHROPIC_API_KEY.
OPENROUTER_API_KEY=
# Slug exacto del modelo (ver https://openrouter.ai/models); opcional,
# tiene un valor por defecto razonable si lo dejas vacío.
OPENROUTER_MODEL=

# Fuerza un proveedor específico ("anthropic" | "openrouter" | "mock"),
# ignorando la lógica automática basada en las keys presentes. Opcional.
AI_PROVIDER=
