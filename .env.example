# Copia este archivo a .env y ajusta los valores. NUNCA commitees el .env real.

# Puerto del servidor HTTP
PORT=3000

# API key de Anthropic (https://platform.claude.com/)
# Solo es necesaria cuando MOCK_CLAUDE=false
ANTHROPIC_API_KEY=

# Modo simulado: "true" devuelve una especificación de ejemplo sin llamar a la
# API de Claude (útil para desarrollar y probar la lógica del endpoint).
# Cambia a "false" cuando tengas tu ANTHROPIC_API_KEY configurada.
MOCK_CLAUDE=true
